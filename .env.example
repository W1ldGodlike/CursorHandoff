# === Core ===
CDP_URL=http://127.0.0.1:9222
SERVER_PORT=3000
SERVER_HOST=127.0.0.1
POLL_INTERVAL_MS=500
DEBOUNCE_MS=300
SELECTORS_PATH=./selectors.json
LOG_LEVEL=info

# === Window Titles ===
# Include remote qualifier ([WSL: ...], [SSH: ...]) in window titles.
# Set to false for cleaner Telegram topic names when you don't need to
# distinguish the same project opened locally and remotely.
# WINDOW_TITLE_QUALIFIER=false

# Projects for /projects and /open_project come from Cursor (opened folders in
# %APPDATA%/Cursor/User/globalStorage/storage.json). Open a folder in Cursor once.

# === Web App Security (optional) ===
# Set a password to protect the web UI. Leave empty for no auth.
WEBAPP_PASSWORD=my-secret-password

# === Telegram Transport (optional) ===
TELEGRAM_ENABLED=false
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Telegram implementation: "raw" (default) or "grammy".
# Default "raw" uses Node fetch with explicit timeouts (recommended for bundled server).
# Switch to "grammy" only if you need Grammy handler routing; see docs/telegram.md.
# TELEGRAM_IMPL=raw

# Optional: hardcode allowed user IDs (overrides /register token auth)
# If set, only these users can use the bot. If not set, anyone with the
# registration token (shown in server console) can /register themselves.
# TELEGRAM_ALLOWED_USERS=123456789,987654321

# === Extension Integration (optional) ===
# These are set automatically when running as a VS Code extension child process.
# Standalone: see docs/reference.md for env vars.
# DATA_DIR=./data
# LOG_FORMAT=text
